{
  "name": "robot-arm-control",
  "version": "1.0.0",
  "description": "6-DOF Robotic Arm Control - โปรแกรมควบคุมแขนกลต้นทุนต่ำ",
  "author": "Low-Cost RobotArm Team",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:start": "electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:linux": "vite build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "lucide-react": "^0.383.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.128.0",
    "serialport": "^12.0.0",
    "@serialport/parser-readline": "^12.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.lowcostrobotarm.control",
    "productName": "Robotic Arm Control",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "win": { "target": ["nsis"], "icon": "electron/icon.png" },
    "mac": { "target": ["dmg"], "icon": "electron/icon.png" },
    "linux": { "target": ["AppImage"], "icon": "electron/icon.png" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true }
  }
}
